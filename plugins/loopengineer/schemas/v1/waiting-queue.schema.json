{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/waiting-queue.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.waitingQueue",
  "title": "LoopEngineer Waiting Queue",
  "description": "Watcher-owned queue of schedulers waiting for shared channel access.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "queue_id",
    "version",
    "channel_id",
    "updated_at",
    "items",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.waitingQueue"
    },
    "queue_id": {
      "type": "string",
      "pattern": "^waiting-queue-[A-Za-z0-9._-]+$"
    },
    "version": {
      "$ref": "report.schema.json#/$defs/version"
    },
    "channel_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      }
    },
    "next_action": {
      "$ref": "report.schema.json#/$defs/nextAction"
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wait_id",
        "scheduler_id",
        "unit_id",
        "request_id",
        "requested_paths",
        "resume_condition",
        "allowed_non_channel_work",
        "forbidden_until_grant",
        "next_readback_at"
      ],
      "properties": {
        "wait_id": {
          "type": "string",
          "minLength": 1
        },
        "scheduler_id": {
          "type": "string",
          "minLength": 1
        },
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "requested_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "resume_condition": {
          "type": "string",
          "minLength": 1
        },
        "allowed_non_channel_work": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_until_grant": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_readback_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
