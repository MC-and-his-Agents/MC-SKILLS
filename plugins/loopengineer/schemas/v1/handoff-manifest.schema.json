{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/handoff-manifest.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.handoffManifest",
  "title": "LoopEngineer Handoff Manifest",
  "description": "A compact, artifact-backed checklist for rotating an agent thread without using retired thread history as a fact source.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "manifest_id",
    "created_at",
    "rotation_reason",
    "state_root",
    "authority",
    "work_scope",
    "current_state",
    "evidence",
    "handoff_checklist",
    "next_owner",
    "next_action",
    "prohibitions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.handoffManifest"
    },
    "manifest_id": {
      "type": "string",
      "pattern": "^handoff-[A-Za-z0-9._-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "rotation_reason": {
      "type": "string",
      "enum": [
        "context_risk",
        "planned_rotation",
        "incident_recovery",
        "owner_change"
      ]
    },
    "state_root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "description"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_sources",
        "forbidden_sources"
      ],
      "properties": {
        "allowed_sources": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "state_root",
              "handoff_manifest",
              "live_facts",
              "git",
              "github",
              "artifacts"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "state_root"
              }
            },
            {
              "contains": {
                "const": "handoff_manifest"
              }
            },
            {
              "contains": {
                "const": "live_facts"
              }
            }
          ]
        },
        "forbidden_sources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "retired_thread_history",
              "old_thread_transcript",
              "memory_only_claim",
              "inline_large_artifact"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "retired_thread_history"
              }
            },
            {
              "contains": {
                "const": "old_thread_transcript"
              }
            }
          ]
        }
      }
    },
    "work_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "current_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "head_sha",
        "workspace",
        "status"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "head_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "in_progress",
            "blocked",
            "ready_for_review",
            "ready_for_handoff",
            "complete"
          ]
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "locator",
          "consumed"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "report",
              "artifact",
              "test",
              "review",
              "git",
              "github"
            ]
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "consumed": {
            "type": "boolean"
          }
        }
      }
    },
    "handoff_checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item",
          "status"
        ],
        "properties": {
          "item": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "done",
              "pending",
              "not_applicable"
            ]
          },
          "locator": {
            "type": "string"
          }
        }
      }
    },
    "next_owner": {
      "type": "string",
      "minLength": 1
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "prohibitions": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "do_not_use_retired_thread_as_fact_source",
          "do_not_inline_large_artifacts",
          "do_not_create_replacement_thread_without_user_or_runtime_action",
          "do_not_implement_recovery_runtime_from_manifest"
        ]
      },
      "contains": {
        "const": "do_not_use_retired_thread_as_fact_source"
      }
    }
  }
}
