{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/scheduler-pool.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.schedulerPool",
  "title": "LoopEngineer Scheduler Pool",
  "description": "A watcher-readable inventory of scheduler ownership, state, and report inboxes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "pool_id",
    "version",
    "created_at",
    "state_root",
    "schedulers",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.schedulerPool"
    },
    "pool_id": {
      "type": "string",
      "pattern": "^scheduler-pool-[A-Za-z0-9._-]+$"
    },
    "version": {
      "$ref": "report.schema.json#/$defs/version"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "state_root": {
      "type": "string",
      "minLength": 1
    },
    "schedulers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scheduler"
      }
    },
    "next_action": {
      "$ref": "report.schema.json#/$defs/nextAction"
    }
  },
  "$defs": {
    "scheduler": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheduler_id",
        "unit_id",
        "status",
        "report_inbox",
        "next_action"
      ],
      "properties": {
        "scheduler_id": {
          "type": "string",
          "minLength": 1
        },
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "thread_id": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "worktree": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "planned",
            "active",
            "blocked",
            "waiting-gate",
            "completed",
            "retired",
            "systemError-retired"
          ]
        },
        "report_inbox": {
          "type": "string",
          "minLength": 1
        },
        "next_action": {
          "$ref": "report.schema.json#/$defs/nextAction"
        }
      }
    }
  }
}
