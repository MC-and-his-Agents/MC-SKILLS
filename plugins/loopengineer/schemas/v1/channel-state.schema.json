{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/channel-state.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.channelState",
  "title": "LoopEngineer Channel State",
  "description": "Watcher-owned shared channel state for coordinating exclusive access to shared resources.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "channel_id",
    "channel_type",
    "state",
    "version",
    "updated_at",
    "release_predicate",
    "waiting_scheduler_ids",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.channelState"
    },
    "channel_id": {
      "type": "string",
      "minLength": 1
    },
    "channel_type": {
      "enum": [
        "shared_fact_chain_status",
        "shadow_carrier",
        "current_item_review",
        "high_cost_gate",
        "merge",
        "contract"
      ]
    },
    "state": {
      "enum": [
        "channel-free",
        "channel-granted",
        "channel-release-pending",
        "channel-blocked",
        "channel-stale-owner",
        "channel-released"
      ]
    },
    "version": {
      "$ref": "report.schema.json#/$defs/version"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "$ref": "#/$defs/owner"
    },
    "owned_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "release_predicate": {
      "type": "string",
      "minLength": 1
    },
    "waiting_scheduler_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "$ref": "report.schema.json#/$defs/nextAction"
    }
  },
  "$defs": {
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheduler_id",
        "unit_id"
      ],
      "properties": {
        "scheduler_id": {
          "type": "string",
          "minLength": 1
        },
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "pr": {
          "type": "string",
          "minLength": 1
        },
        "head_sha": {
          "type": "string",
          "minLength": 7
        }
      }
    }
  }
}
