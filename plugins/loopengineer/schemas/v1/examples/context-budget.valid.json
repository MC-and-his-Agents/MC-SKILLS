{
  "schemaVersion": "1.0",
  "kind": "loopengineer.contextBudget",
  "estimation": {
    "method": "deterministic_approx_v1",
    "charsPerToken": 4,
    "lineOverheadTokens": 1,
    "codeFenceOverheadTokens": 8
  },
  "profiles": {
    "confirmation": {
      "description": "Short confirmation.",
      "budgetTokens": 120,
      "warnAtTokens": 90,
      "overflowAction": "write_artifact_send_locator",
      "allowedInline": [
        "decision",
        "next_action"
      ],
      "artifactRequiredFor": [
        "full logs"
      ]
    },
    "locator": {
      "description": "Artifact pointer.",
      "budgetTokens": 240,
      "warnAtTokens": 180,
      "overflowAction": "write_artifact_send_locator",
      "allowedInline": [
        "path",
        "summary"
      ],
      "artifactRequiredFor": [
        "artifact body"
      ]
    },
    "cross_thread": {
      "description": "Cross-thread task message.",
      "budgetTokens": 800,
      "warnAtTokens": 600,
      "overflowAction": "write_artifact_send_locator",
      "allowedInline": [
        "goal",
        "next_action"
      ],
      "artifactRequiredFor": [
        "complete prior thread"
      ]
    },
    "initial_prompt": {
      "description": "New loop prompt.",
      "budgetTokens": 2400,
      "warnAtTokens": 1800,
      "overflowAction": "write_artifact_send_locator",
      "allowedInline": [
        "objective",
        "acceptance"
      ],
      "artifactRequiredFor": [
        "full issue history"
      ]
    },
    "heartbeat_prompt": {
      "description": "Loop heartbeat prompt.",
      "budgetTokens": 900,
      "warnAtTokens": 675,
      "overflowAction": "rotate_thread",
      "allowedInline": [
        "current_status",
        "next_action"
      ],
      "artifactRequiredFor": [
        "old thread content"
      ]
    },
    "handoff_prompt": {
      "description": "Fresh thread handoff prompt.",
      "budgetTokens": 1600,
      "warnAtTokens": 1200,
      "overflowAction": "rotate_thread",
      "allowedInline": [
        "objective",
        "authoritative_sources"
      ],
      "artifactRequiredFor": [
        "retired thread turns"
      ]
    }
  }
}
