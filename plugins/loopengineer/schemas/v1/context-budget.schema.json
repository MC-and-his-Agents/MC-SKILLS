{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/context-budget.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.contextBudget",
  "title": "LoopEngineer context budget",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "estimation",
    "profiles"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.contextBudget"
    },
    "estimation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "charsPerToken",
        "lineOverheadTokens",
        "codeFenceOverheadTokens"
      ],
      "properties": {
        "method": {
          "const": "deterministic_approx_v1"
        },
        "charsPerToken": {
          "type": "integer",
          "minimum": 1
        },
        "lineOverheadTokens": {
          "type": "integer",
          "minimum": 0
        },
        "codeFenceOverheadTokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmation",
        "locator",
        "cross_thread",
        "initial_prompt",
        "heartbeat_prompt",
        "handoff_prompt"
      ],
      "properties": {
        "confirmation": {
          "$ref": "#/$defs/profile"
        },
        "locator": {
          "$ref": "#/$defs/profile"
        },
        "cross_thread": {
          "$ref": "#/$defs/profile"
        },
        "initial_prompt": {
          "$ref": "#/$defs/profile"
        },
        "heartbeat_prompt": {
          "$ref": "#/$defs/profile"
        },
        "handoff_prompt": {
          "$ref": "#/$defs/profile"
        }
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "budgetTokens",
        "warnAtTokens",
        "overflowAction",
        "allowedInline",
        "artifactRequiredFor"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "budgetTokens": {
          "type": "integer",
          "minimum": 1
        },
        "warnAtTokens": {
          "type": "integer",
          "minimum": 1
        },
        "overflowAction": {
          "enum": [
            "write_artifact_send_locator",
            "rotate_thread"
          ]
        },
        "allowedInline": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "artifactRequiredFor": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
