{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/subagent-assignment.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.subagentAssignment",
  "title": "LoopEngineer Subagent Assignment",
  "description": "A bounded worker_lite assignment for a subagent execution provider.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "assignment_id",
    "unit_id",
    "instruction_id",
    "provider",
    "agent_id",
    "thread_id",
    "objective_digest",
    "allowed_read_paths",
    "allowed_write_paths",
    "forbidden_scope",
    "expected_report_type",
    "report_output_path",
    "validation_expectation",
    "next_owner",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.subagentAssignment"
    },
    "assignment_id": {
      "type": "string",
      "pattern": "^assignment-[A-Za-z0-9._-]+$"
    },
    "unit_id": {
      "type": "string",
      "minLength": 1
    },
    "instruction_id": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "const": "subagent"
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "thread_id": {
      "type": "string",
      "minLength": 1
    },
    "objective_digest": {
      "type": "string",
      "minLength": 1
    },
    "allowed_read_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_write_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "state_transition",
          "shared_channel",
          "gate",
          "merge",
          "release",
          "closeout",
          "external_write"
        ]
      }
    },
    "expected_report_type": {
      "enum": [
        "instruction_ack",
        "startup_report",
        "progress_update",
        "blocker_update",
        "completion_result",
        "gate_wait",
        "routing_missing",
        "correction_result"
      ]
    },
    "report_output_path": {
      "type": "string",
      "minLength": 1
    },
    "validation_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "commands"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "next_owner": {
      "enum": [
        "worker",
        "scheduler",
        "watcher",
        "user"
      ]
    },
    "next_action": {
      "$ref": "#/$defs/nextAction"
    }
  },
  "$defs": {
    "nextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "action",
        "status"
      ],
      "properties": {
        "owner": {
          "enum": [
            "worker",
            "scheduler",
            "watcher",
            "user",
            "external"
          ]
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "required",
            "blocked",
            "waiting",
            "none"
          ]
        }
      }
    }
  }
}
