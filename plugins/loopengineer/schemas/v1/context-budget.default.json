{
  "schemaVersion": "1.0",
  "kind": "loopengineer.contextBudget",
  "estimation": {
    "method": "deterministic_approx_v1",
    "charsPerToken": 4,
    "lineOverheadTokens": 1,
    "codeFenceOverheadTokens": 8
  },
  "profiles": {
    "confirmation": {
      "description": "Short acknowledgement or decision confirmation.",
      "budgetTokens": 120,
      "warnAtTokens": 90,
      "overflowAction": "write_artifact_send_locator",
      "allowedInline": [
        "decision",
        "status",
        "next_action"
      ],
      "artifactRequiredFor": [
        "full logs",
        "full diffs",
        "full reports"
      ]
    },
    "locator": {
      "description": "Compact pointer to an artifact, command, source, or state carrier.",
      "budgetTokens": 240,
      "warnAtTokens": 180,
      "overflowAction": "write_artifact_send_locator",
      "allowedInline": [
        "path",
        "source",
        "timestamp",
        "head_sha",
        "summary"
      ],
      "artifactRequiredFor": [
        "artifact body",
        "large status table",
        "old thread content"
      ]
    },
    "cross_thread": {
      "description": "Message sent between agent threads or workstreams.",
      "budgetTokens": 800,
      "warnAtTokens": 600,
      "overflowAction": "write_artifact_send_locator",
      "allowedInline": [
        "goal",
        "scope",
        "inputs",
        "acceptance",
        "next_owner",
        "next_action"
      ],
      "artifactRequiredFor": [
        "full logs",
        "full diffs",
        "complete reports",
        "complete prior thread"
      ]
    },
    "initial_prompt": {
      "description": "Initial task prompt for a new agent loop.",
      "budgetTokens": 2400,
      "warnAtTokens": 1800,
      "overflowAction": "write_artifact_send_locator",
      "allowedInline": [
        "objective",
        "scope",
        "constraints",
        "inputs",
        "acceptance",
        "verification"
      ],
      "artifactRequiredFor": [
        "full requirements corpus",
        "full issue history",
        "full logs",
        "full diffs"
      ]
    },
    "heartbeat_prompt": {
      "description": "Recurring or follow-up prompt that resumes an existing loop.",
      "budgetTokens": 900,
      "warnAtTokens": 675,
      "overflowAction": "rotate_thread",
      "allowedInline": [
        "current_status",
        "blocking_condition",
        "latest_evidence",
        "next_action"
      ],
      "artifactRequiredFor": [
        "complete progress log",
        "complete report list",
        "old thread content"
      ]
    },
    "handoff_prompt": {
      "description": "Prompt that transfers ownership to a fresh thread or agent.",
      "budgetTokens": 1600,
      "warnAtTokens": 1200,
      "overflowAction": "rotate_thread",
      "allowedInline": [
        "objective",
        "current_state",
        "authoritative_sources",
        "verification",
        "next_owner",
        "next_action"
      ],
      "artifactRequiredFor": [
        "full artifacts",
        "full logs",
        "full diffs",
        "retired thread turns"
      ]
    }
  }
}
