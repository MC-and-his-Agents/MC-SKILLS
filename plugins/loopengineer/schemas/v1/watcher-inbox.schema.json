{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/watcher-inbox.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.watcherInbox",
  "title": "LoopEngineer Watcher Inbox",
  "description": "A compact watcher-readable inbox that points to scheduler reports, channel events, stale targets, candidate units, and required next actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "inbox_id",
    "version",
    "watcher_id",
    "generated_at",
    "state_root",
    "sources",
    "summary",
    "unconsumed_scheduler_reports",
    "unconsumed_channel_events",
    "unacked_scheduler_instructions",
    "stale_heartbeat_targets",
    "stale_channel_owners",
    "candidate_units",
    "required_next_actions",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.watcherInbox"
    },
    "inbox_id": {
      "type": "string",
      "pattern": "^watcher-inbox-[A-Za-z0-9._-]+$"
    },
    "version": {
      "$ref": "report.schema.json#/$defs/version"
    },
    "watcher_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "state_root": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "report.schema.json#/$defs/locator"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unconsumed_report_count",
        "unconsumed_channel_event_count",
        "unacked_instruction_count",
        "stale_heartbeat_count",
        "stale_channel_owner_count",
        "candidate_unit_count",
        "required_next_action_count"
      ],
      "properties": {
        "unconsumed_report_count": {
          "type": "integer",
          "minimum": 0
        },
        "unconsumed_channel_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "unacked_instruction_count": {
          "type": "integer",
          "minimum": 0
        },
        "stale_heartbeat_count": {
          "type": "integer",
          "minimum": 0
        },
        "stale_channel_owner_count": {
          "type": "integer",
          "minimum": 0
        },
        "candidate_unit_count": {
          "type": "integer",
          "minimum": 0
        },
        "required_next_action_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "unconsumed_scheduler_reports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reportNotice"
      }
    },
    "unconsumed_channel_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/channelEventNotice"
      }
    },
    "unacked_scheduler_instructions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/instructionNotice"
      }
    },
    "stale_heartbeat_targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/staleHeartbeatTarget"
      }
    },
    "stale_channel_owners": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/staleChannelOwner"
      }
    },
    "candidate_units": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidateUnit"
      }
    },
    "required_next_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requiredNextAction"
      }
    },
    "next_action": {
      "$ref": "report.schema.json#/$defs/nextAction"
    }
  },
  "$defs": {
    "reportNotice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "scheduler_id",
        "report_path",
        "report_type",
        "created_at"
      ],
      "properties": {
        "report_id": {
          "type": "string",
          "pattern": "^report-[A-Za-z0-9._-]+$"
        },
        "scheduler_id": {
          "type": "string",
          "minLength": 1
        },
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "report_path": {
          "type": "string",
          "minLength": 1
        },
        "report_type": {
          "enum": [
            "instruction_ack",
            "startup_report",
            "progress_update",
            "blocker_update",
            "completion_result",
            "gate_wait",
            "routing_missing",
            "correction_result"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "channelEventNotice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "channel_id",
        "event_path",
        "created_at"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "pattern": "^channel-event-[A-Za-z0-9._-]+$"
        },
        "event_type": {
          "enum": [
            "request",
            "grant",
            "wait",
            "deny",
            "release"
          ]
        },
        "channel_id": {
          "type": "string",
          "minLength": 1
        },
        "scheduler_id": {
          "type": "string",
          "minLength": 1
        },
        "event_path": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "instructionNotice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instruction_id",
        "scheduler_id",
        "sent_at",
        "expected_report_type",
        "next_readback_at"
      ],
      "properties": {
        "instruction_id": {
          "type": "string",
          "minLength": 1
        },
        "scheduler_id": {
          "type": "string",
          "minLength": 1
        },
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "sent_at": {
          "type": "string",
          "format": "date-time"
        },
        "expected_report_type": {
          "enum": [
            "instruction_ack",
            "startup_report",
            "progress_update",
            "blocker_update",
            "completion_result",
            "gate_wait",
            "routing_missing",
            "correction_result"
          ]
        },
        "next_readback_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "staleHeartbeatTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheduler_id",
        "expected_thread_id",
        "observed_thread_id",
        "last_checked_at"
      ],
      "properties": {
        "scheduler_id": {
          "type": "string",
          "minLength": 1
        },
        "expected_thread_id": {
          "type": "string",
          "minLength": 1
        },
        "observed_thread_id": {
          "type": "string",
          "minLength": 1
        },
        "last_checked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "staleChannelOwner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_id",
        "owner_scheduler_id",
        "stale_reason",
        "next_readback_at"
      ],
      "properties": {
        "channel_id": {
          "type": "string",
          "minLength": 1
        },
        "owner_scheduler_id": {
          "type": "string",
          "minLength": 1
        },
        "stale_reason": {
          "type": "string",
          "minLength": 1
        },
        "next_readback_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "candidateUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit_id",
        "readiness",
        "source"
      ],
      "properties": {
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "readiness": {
          "enum": [
            "ready",
            "blocked",
            "needs_readback"
          ]
        },
        "source": {
          "$ref": "report.schema.json#/$defs/locator"
        }
      }
    },
    "requiredNextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "action",
        "source"
      ],
      "properties": {
        "owner": {
          "enum": [
            "worker",
            "scheduler",
            "watcher",
            "user",
            "external"
          ]
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "report.schema.json#/$defs/locator"
        }
      }
    }
  }
}
