{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/channel-event.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.channelEvent",
  "title": "LoopEngineer Channel Event",
  "description": "A request, grant, wait, denial, or release event for shared channel coordination.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "event_id",
    "event_type",
    "version",
    "channel_id",
    "scheduler_id",
    "unit_id",
    "created_at",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.channelEvent"
    },
    "event_id": {
      "type": "string",
      "pattern": "^channel-event-[A-Za-z0-9._-]+$"
    },
    "event_type": {
      "enum": [
        "request",
        "grant",
        "wait",
        "deny",
        "release"
      ]
    },
    "version": {
      "$ref": "report.schema.json#/$defs/version"
    },
    "channel_id": {
      "type": "string",
      "minLength": 1
    },
    "scheduler_id": {
      "type": "string",
      "minLength": 1
    },
    "unit_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "granted_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "grant_scope": {
      "type": "string",
      "minLength": 1
    },
    "current_pr": {
      "type": "string",
      "minLength": 1
    },
    "current_head": {
      "type": "string",
      "minLength": 7
    },
    "current_base": {
      "type": "string",
      "minLength": 7
    },
    "release_predicate": {
      "type": "string",
      "minLength": 1
    },
    "required_report_after_action": {
      "type": "string",
      "minLength": 1
    },
    "next_action": {
      "$ref": "report.schema.json#/$defs/nextAction"
    }
  }
}
