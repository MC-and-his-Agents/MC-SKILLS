{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/dispatch-table.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.dispatchTable",
  "title": "LoopEngineer Dispatch Table",
  "description": "A scheduler-owned table of worker instructions and report expectations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "table_id",
    "version",
    "scheduler_id",
    "created_at",
    "state_root",
    "entries",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.dispatchTable"
    },
    "table_id": {
      "type": "string",
      "pattern": "^dispatch-[A-Za-z0-9._-]+$"
    },
    "version": {
      "$ref": "report.schema.json#/$defs/version"
    },
    "scheduler_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "state_root": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "next_action": {
      "$ref": "report.schema.json#/$defs/nextAction"
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instruction_id",
        "unit_id",
        "status",
        "expected_report_type",
        "report_output_path",
        "report_to_thread_id",
        "assigned_scope",
        "next_action"
      ],
      "properties": {
        "instruction_id": {
          "type": "string",
          "minLength": 1
        },
        "unit_id": {
          "type": "string",
          "minLength": 1
        },
        "worker_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "instruction-sent-awaiting-ack",
            "confirming",
            "active",
            "waiting-report",
            "waiting-scheduler-gate",
            "blocked",
            "completed",
            "failed",
            "replacement-planned"
          ]
        },
        "expected_report_type": {
          "type": "string",
          "minLength": 1
        },
        "report_output_path": {
          "type": "string",
          "minLength": 1
        },
        "report_to_thread_id": {
          "type": "string",
          "minLength": 1
        },
        "assigned_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_action": {
          "$ref": "report.schema.json#/$defs/nextAction"
        }
      }
    }
  }
}
