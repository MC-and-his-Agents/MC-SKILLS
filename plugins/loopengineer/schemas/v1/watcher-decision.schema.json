{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MC-and-his-Agents/LoopEngineer/schemas/v1/watcher-decision.schema.json",
  "schemaVersion": "1.0",
  "kind": "loopengineer.watcherDecision",
  "title": "LoopEngineer Watcher Decision",
  "description": "A compact watcher decision record backed by state and report locators.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "decision_id",
    "decision_type",
    "version",
    "watcher_id",
    "created_at",
    "inputs",
    "rationale",
    "next_action"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "kind": {
      "const": "loopengineer.watcherDecision"
    },
    "decision_id": {
      "type": "string",
      "pattern": "^watcher-decision-[A-Za-z0-9._-]+$"
    },
    "decision_type": {
      "enum": [
        "grant_channel",
        "deny_channel",
        "wait",
        "readback",
        "recover_scheduler",
        "release_channel",
        "noop"
      ]
    },
    "version": {
      "$ref": "report.schema.json#/$defs/version"
    },
    "watcher_id": {
      "type": "string",
      "minLength": 1
    },
    "target_channel_id": {
      "type": "string",
      "minLength": 1
    },
    "target_scheduler_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "report.schema.json#/$defs/locator"
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "next_action": {
      "$ref": "report.schema.json#/$defs/nextAction"
    }
  }
}
